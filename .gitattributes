* text=auto

# Keep shell scripts on LF and batch files on CRLF.
*.sh text eol=lf
gradlew text eol=lf
*.bat text eol=crlf

# Kotlin / Gradle / XML / docs
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.properties text eol=lf
*.pro text eol=lf
*.txt text eol=lf

# Binary assets
*.png binary
*.webp binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.keystore binary
*.jks binary
*.apk binary
*.aab binary
*.so binary
